# ── Environment ────────────────────────────────────────────
.env
.env.local
.env.production

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/

# ── Input files — never commit real footage or photos ──────
input/*.mp4
input/*.avi
input/*.mov
input/*.jpg
input/*.jpeg
input/*.png
input/*.JPG
input/*.PNG
# Keep the folder
!input/.gitkeep

# ── Output files — generated, not source ───────────────────
output/stills/*.jpg
output/stills/*.jpeg
output/stills/*.png
output/reports/*.pdf
!output/stills/.gitkeep
!output/reports/.gitkeep

# ── Data files — generated by pipeline ─────────────────────
data/*.csv
data/*.json
!data/.gitkeep

# ── Database — never commit real offender photos ───────────
database/*.jpg
database/*.jpeg
database/*.png
database/*.JPG
!database/.gitkeep

# ── ML model weights — large files, auto-downloaded ────────
*.pt
*.pth
*.onnx
*.pkl
buffalo_l/
models/

# ── InsightFace model cache ─────────────────────────────────
.insightface/

# ── VS Code ─────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── macOS ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Coverage ────────────────────────────────────────────────
.coverage
htmlcov/

# ── pytest ──────────────────────────────────────────────────
.pytest_cache/

# ── mypy ────────────────────────────────────────────────────
.mypy_cache/
